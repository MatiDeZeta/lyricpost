# Server-side (Vercel → Settings → Environment Variables)
# Required for song search. Use LASTFM_API_KEY (not VITE_*).
LASTFM_API_KEY=your_lastfm_api_key_here

# Legacy fallback only — prefer LASTFM_API_KEY above
# VITE_LASTFM_API_KEY=your_lastfm_api_key_here

# Optional: privacy-friendly analytics (client-side, public)
VITE_PLAUSIBLE_DOMAIN=yourdomain.com

# Optional: canonical site URL for SEO meta tags
VITE_SITE_URL=https://yourdomain.com
